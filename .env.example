# Copy to .env.local and fill values. Never commit real secrets.

# --- Supabase (required in production) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Rate limiting — Upstash Redis (required in production) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# --- PII encryption (required in production if encryption routes are used) ---
# New writes use v2 JSON envelope (prefix v2:). Legacy v1 iv:tag:ciphertext hex is still decrypted.
ENCRYPTION_KEY=
# Optional; default salt string used if unset (prefer setting in production).
# ENCRYPTION_KEY_SALT=

# --- Event commerce check-in token HMAC (recommended in production) ---
# EVENT_CHECKIN_PEPPER=

# --- Optional: observability ---
# NEXT_PUBLIC_SENTRY_DSN=
# Splits dev/preview/production in Sentry (defaults to VERCEL_ENV or NODE_ENV).
# SENTRY_ENVIRONMENT=production

# --- Optional: database direct / marketing ---
# DATABASE_URL=
# POSTGRES_CONNECTION_STRING=
# RESEND_API_KEY=

# --- Optional: social OAuth (per provider) ---
# SOCIALS_OAUTH_REDIRECT_URI=http://localhost:3000/api/socials/oauth/callback
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# --- Optional: OSS / marketing (landing “Star on GitHub”) ---
# NEXT_PUBLIC_REPO_URL=https://github.com/your-org/urban-bar-crm

# --- Optional: payments & messaging (plugin opt-in — webhooks stay 404 until enabled) ---
# Integration toggles are optional; if your deployment stores provider settings in DB,
# keep env values as secure fallbacks for local/dev.
#
# Turn on only the providers you use (server env; not exposed to the browser):
# INTEGRATION_STRIPE_ENABLED=1
# INTEGRATION_TWILIO_ENABLED=1
# INTEGRATION_RESEND_ENABLED=1
# INTEGRATION_GOOGLE_REVIEWS_ENABLED=1
#
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# GOOGLE_PLACES_API_KEY=

# --- Optional: Web Push (PWA) — ensure push subscription tables exist in your schema, then generate VAPID keys ---
# npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT_MAILTO=mailto:ops@your-domain.com
# Disable Serwist during local experiments: DISABLE_SERWIST=1
