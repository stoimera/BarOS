{
  "name": "baros",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/app/api/**/*.ts\" \"src/lib/security/**/*.ts\" \"src/lib/logger.ts\" \"scripts/**/*.mjs\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=__tests__/components",
    "test:integration": "jest --testPathPatterns=__tests__/stores",
    "test:e2e": "jest --testPathPatterns=__tests__/e2e",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:a11y": "jest --ci --watchAll=false --testPathPatterns=__tests__/a11y --collectCoverage=false",
    "security:coverage": "node scripts/security/route-coverage.mjs",
    "security:enforce": "npm run security:coverage",
    "verify:no-todos": "node scripts/verify/no-todos.mjs",
    "verify:no-console": "node scripts/verify/no-console.mjs",
    "verify:wrapper": "node scripts/verify/wrapper-coverage.mjs",
    "verify:rls": "node scripts/verify/rls-enabled.mjs",
    "verify:audit": "node scripts/verify/audit-log-coverage.mjs",
    "verify:ui-routes": "node scripts/verify/ui-route-reachable.mjs",
    "verify:schema": "node scripts/verify/schema-matches-csv.mjs",
    "verify:secrets": "node scripts/verify/secrets-scan.mjs",
    "verify:service-role-imports": "node scripts/verify/service-role-imports.mjs",
    "verify:all": "npm run verify:no-todos && npm run verify:no-console && npm run verify:wrapper && npm run verify:rls && npm run verify:audit && npm run verify:ui-routes && npm run verify:schema && npm run verify:service-role-imports && npm run verify:secrets",
    "create-admin": "tsx src/scripts/createAdminUser.ts"
  },
  "dependencies": {
    "@google/genai": "^1.12.0",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@sentry/nextjs": "^10.26.0",
    "@serwist/next": "^9.5.7",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.52.1",
    "@tanstack/react-query": "^5.81.5",
    "@tanstack/react-query-devtools": "^5.81.5",
    "@types/pg": "^8.15.4",
    "@types/qrcode": "^1.5.5",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@zxing/browser": "^0.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.0.1",
    "lucide-react": "^0.525.0",
    "next": "15.3.8",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "recharts": "^3.0.2",
    "resend": "^4.6.0",
    "serwist": "^9.5.7",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "web-push": "^3.6.7",
    "zod": "^3.25.67",
    "zustand": "^5.0.6"
  },
  "overrides": {
    "@swc/helpers": "0.5.21"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
